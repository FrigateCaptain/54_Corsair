<header class="site-header">
    <div class="site-header__inner">
        <a href="{{@site.url}}" class="site-header__logo">
            {{#if @site.logo}}
                <img src="{{@site.logo}}" alt="{{@site.title}}">
            {{else}}
                {{@site.title}}
            {{/if}}
        </a>
        <nav class="site-header__nav">
            <ul>
                {{#foreach @site.navigation}}
                    <li><a href="{{url}}">{{label}}</a></li>
                {{/foreach}}
            </ul>
        </nav>
    </div>
</header>
