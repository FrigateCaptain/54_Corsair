<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{@blog.title}}</title>
    <link rel="stylesheet" href="{{asset 'css/screen.css'}}">
</head>
<body>
    <header class="site-header">
        <div class="site-header-content">
            <h1 class="site-title">{{@blog.title}}</h1>
        </div>
    </header>

    <section class="hero">
        <div class="hero-container">
            <div class="hero-content">
                <h1 class="hero-title">ОПЫТО-КОНСТРУКТОРСКОЕ БЮРО</h1>
                <p class="hero-subtitle">Создаём решения, которые работают</p>
                <button class="hero-cta">ОБСУДИТЬ ЗАДАЧУ</button>
            </div>
        </div>
    </section>

    <main class="main-content">
        <div class="posts-grid">
            {{#foreach posts}}
                <article class="post-card">
                    <h2 class="post-title">
                        <a href="{{url}}">{{title}}</a>
                    </h2>
                    <div class="post-excerpt">
                        {{excerpt words="30"}}
                    </div>
                    <a href="{{url}}" class="read-more">Read More →</a>
                </article>
            {{/foreach}}
        </div>
    </main>

    <footer class="site-footer">
        <div class="footer-content">
            <p>&copy; {{date format="YYYY"}} {{@blog.title}}. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
